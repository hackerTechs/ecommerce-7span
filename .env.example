DATABASE_URL="mysql://root:root@localhost:3306/ecommerce_7_span"

SERVER_PORT=5000
# Access token (short-lived, httpOnly cookie)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token (long-lived, httpOnly cookie) — use a distinct secret in production
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
# Legacy: if JWT_ACCESS_SECRET unset, JWT_SECRET is used for access only
JWT_SECRET=super-secret-jwt-key-change-in-production
NODE_ENV=development
# CORS origin for browser + Socket.IO (Vite dev default)
CLIENT_URL=http://localhost:3000

# Catalog cache (categories + product list/detail). Leave empty to disable Redis.
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

CLIENT_PORT=3000
VITE_API_URL=http://localhost:5000/api
